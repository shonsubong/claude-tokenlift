{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TokenLift 설정",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "provider": { "type": "string", "description": "활성 백엔드 이름(ollama | nemoclaw | ...)" },
    "ollama": {
      "type": "object",
      "properties": {
        "host": { "type": "string", "description": "Ollama 엔드포인트 URL" },
        "timeoutMs": { "type": "integer", "minimum": 1000, "description": "요청 타임아웃(ms)" },
        "keepAlive": { "type": "string", "description": "모델 메모리 상주 시간(예: 30m)" },
        "numCtx": { "type": "integer", "minimum": 512, "description": "기본 컨텍스트 윈도우 토큰" }
      }
    },
    "providers": {
      "type": "object",
      "description": "추가 백엔드(provider) 정의. ollama 외 백엔드를 키로 추가.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["ollama", "openai-compat"], "description": "어댑터 타입" },
          "host": { "type": "string", "description": "백엔드 호스트 URL" },
          "apiPath": { "type": "string", "description": "(openai-compat) API 경로 prefix, 기본 /v1" },
          "apiKey": { "type": "string", "description": "(openai-compat) Bearer 키(비밀은 apiKeyEnv 권장)" },
          "apiKeyEnv": { "type": "string", "description": "(openai-compat) Bearer 키를 읽을 환경변수명" },
          "extraHeaders": { "type": "object", "description": "(openai-compat) 추가 HTTP 헤더" },
          "supportsFIM": { "type": "boolean", "description": "(openai-compat) /v1/completions(FIM) 지원 여부" },
          "keepAlive": { "type": "string", "description": "(ollama) 모델 상주 시간" },
          "numCtx": { "type": "integer", "description": "(ollama) 컨텍스트 윈도우" },
          "timeoutMs": { "type": "integer", "description": "요청 타임아웃(ms)" },
          "models": {
            "type": "array", "items": { "type": "string" },
            "description": "/v1/models 미지원 시 모델명 수동 목록"
          },
          "routing": {
            "type": "object",
            "properties": {
              "default": { "type": "string" },
              "byTask": { "type": "object", "additionalProperties": { "type": "string" } }
            }
          }
        },
        "required": ["type"]
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "default": { "type": "string" },
        "byTask": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "fallback": { "type": "string" }
      },
      "required": ["default"]
    },
    "pricing": {
      "type": "object",
      "description": "절감 추정용 Bedrock 단가(USD per 1M tokens)",
      "properties": {
        "label": { "type": "string" },
        "inputPer1M": { "type": "number", "minimum": 0 },
        "outputPer1M": { "type": "number", "minimum": 0 }
      }
    },
    "thresholds": {
      "type": "object",
      "properties": {
        "delegateMinOutputLines": { "type": "integer", "minimum": 0 },
        "delegateMinFileLines": { "type": "integer", "minimum": 0 },
        "delegateMinFiles": { "type": "integer", "minimum": 0 }
      }
    },
    "generation": {
      "type": "object",
      "properties": {
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "topP": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "file": { "type": "string" }
      }
    }
  }
}
